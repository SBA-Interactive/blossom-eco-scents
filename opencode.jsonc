{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "magicui": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@magicuidesign/mcp@latest"
      ],
      "enabled": true,
      "environment": {}
    },
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "shadcn": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "environment": {}
    }
  }
}

